# ==============================================================================
# Security & Sensitive Data (Crucial for Public GitHub Repos)
# ==============================================================================
# Ignore any accidental env or local credential files
*.env
*.env.*
.envrc
*.secret
*.token
*secret*
*credential*

# Ignore active private keys, certificates, or SSH fragments
*.pem
*.key
*.pub
id_rsa
id_edd25519

# ==============================================================================
# Neovim / Vim Specifics (config/nvim)
# ==============================================================================
# Ignore local machine modifications or machine-specific configs
config/nvim/lua/machine/local.lua

# Ignore runtime data, caches, undo histories, and swap files if they leak into here
config/nvim/.netrwhist
config/nvim/lazy-lock.json.bak
*.swp
*.swo
*~
.nfs*

# ==============================================================================
# Shell History & Caches (zsh)
# ==============================================================================
# Shell history often leaks plain-text passwords and API tokens
.zhistory
.zsh_history
.history
.zcompdump*
*.zwc

# ==============================================================================
# System, Desktop Environment, & Application Caches
# ==============================================================================
# OS generated files
.DS_Store
.directory
Thumbs.db

# App specific runtime states/caches that shouldn't be tracked
config/btop/btop.log
config/walker/cache/
config/walker/history/
