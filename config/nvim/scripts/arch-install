#!/usr/bin/env bash

set -euo pipefail

# nvimz: Arch Linux Dependency Installer

echo "--------------------------------------------------"
echo " nvimz: Arch Linux Installation"
echo "--------------------------------------------------"

# Check if pacman is available
if ! command -v pacman >/dev/null 2>&1; then
  echo "❌ Error: pacman not found. This script is intended for Arch Linux."
  exit 1
fi

PACKAGES=(
  neovim
  git
  ripgrep
  fd
  go
  lua-language-server
  stylua
  shfmt
  gcc
  make
)

INSTALL_CMD="sudo pacman -Syu --needed"

if command -v yay >/dev/null 2>&1; then
  INSTALL_CMD="yay -S --needed"
elif command -v paru >/dev/null 2>&1; then
  INSTALL_CMD="paru -S --needed"
fi

echo "⏳ Updating system and installing dependencies..."
$INSTALL_CMD "${PACKAGES[@]}"

echo "⏳ Installing gopls via Go..."
go install golang.org/x/tools/gopls@latest

echo "✅ System dependencies installed."

# Run the parsers script
if [ -f "./scripts/parsers" ]; then
  echo "⏳ Installing Treesitter parsers..."
  ./scripts/parsers
fi

echo "--------------------------------------------------"
echo "Arch Linux setup complete! Launch with 'nvim'."
