#!/usr/bin/env bash

set -euo pipefail

TOOLS=(
  git
  rg
  fd
  gopls
  lua-language-server
  stylua
  shfmt
)

printf "\n"

for tool in "${TOOLS[@]}"; do
  if command -v "$tool" >/dev/null 2>&1; then
    printf "%-24s OK\n" "$tool"
  else
    printf "%-24s MISSING\n" "$tool"
  fi
done

printf "\nTreesitter Parsers:\n"
PARSERS=("c" "cpp" "go" "rust" "python" "typescript" "tsx")
PARSER_DIR="${HOME}/.local/share/nvim/site/parser"

for parser in "${PARSERS[@]}"; do
  if [ -f "$PARSER_DIR/$parser.so" ]; then
    printf "%-24s OK\n" "$parser"
  else
    printf "%-24s MISSING\n" "$parser"
  fi
done

printf "\n"
