#!/usr/bin/env bash

set -euo pipefail

# nvimz: Machine-specific setup script

LOCAL_CONFIG="lua/machine/local.lua"
EXAMPLE_CONFIG="lua/machine/example.lua"

echo "--------------------------------------------------"
echo " nvimz: Machine Setup"
echo "--------------------------------------------------"

if [ ! -f "$LOCAL_CONFIG" ]; then
  echo "⏳ Creating $LOCAL_CONFIG from example..."
  cp "$EXAMPLE_CONFIG" "$LOCAL_CONFIG"
  echo "✅ Created $LOCAL_CONFIG. Please edit it to match your machine setup."
else
  echo "✅ $LOCAL_CONFIG already exists."
fi

# Detect Python path
PYTHON_PATH=$(command -v python3 || command -v python || echo "")
if [ -n "$PYTHON_PATH" ]; then
  echo "💡 Detected Python at: $PYTHON_PATH"
  # Optional: Update the path in local.lua automatically? 
  # Better to let the user do it or keep it simple.
fi

echo "--------------------------------------------------"
echo "Machine setup complete!"
